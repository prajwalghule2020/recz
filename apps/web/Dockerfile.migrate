FROM node:22-alpine

WORKDIR /app

# Install prisma CLI — pinned to v6 to match project (prisma@7 is a breaking change)
RUN npm install -g prisma@6

# Copy the shared DB schema and migrations
COPY packages/db/prisma ./prisma

# Default command: run migrations
CMD ["prisma", "migrate", "deploy", "--schema=./prisma/schema.prisma"]
